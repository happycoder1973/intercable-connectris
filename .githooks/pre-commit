#!/bin/sh

# Find all staged .gd files, excluding third-party addons
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.gd$' | grep -v '^addons/')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FAILED=0

echo "Checking staged GDScript files..."

for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        echo "Linter and Formatter check for: $FILE"
        
        # Check formatting
        python -m gdtoolkit.formatter --check "$FILE"
        FORMAT_STATUS=$?
        
        # Check linting
        python -m gdtoolkit.linter "$FILE"
        LINT_STATUS=$?
        
        if [ $FORMAT_STATUS -ne 0 ]; then
            echo "[FAIL] $FILE has formatting issues. Run 'python -m gdtoolkit.formatter <file>' to fix."
            FAILED=1
        fi
        
        if [ $LINT_STATUS -ne 0 ]; then
            echo "[FAIL] $FILE has linting issues."
            FAILED=1
        fi
    fi
done

if [ $FAILED -ne 0 ]; then
    echo "Commit blocked. Please resolve the issues above."
    exit 1
fi

echo "All checks passed!"
exit 0